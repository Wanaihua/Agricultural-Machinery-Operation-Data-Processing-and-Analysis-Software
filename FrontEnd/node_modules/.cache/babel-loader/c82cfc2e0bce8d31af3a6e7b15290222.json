{"ast":null,"code":"export default {\n  name: \"Aside\",\n  props: {\n    isCollapse: Boolean,\n    logoTextShow: Boolean,\n    menus: Array\n  },\n  methods: {\n    handleSelect() {\n      this.$route.fullPath.split(\"/\");\n    }\n  }\n};","map":{"version":3,"mappings":"AA0CA;EACAA;EACAC;IACAC;IACAC;IACAC;EACA;EACAC;IACAC;MACA;IACA;EACA;AACA","names":["name","props","isCollapse","logoTextShow","menus","methods","handleSelect"],"sourceRoot":"src/components","sources":["Aside.vue"],"sourcesContent":["<template>\n  <el-menu :default-openeds=\"['1', '3']\" style=\"min-height: 100%;overflow-x: hidden;\"\n           background-color=\"rgb(48,65,86)\"\n           text-color=\"#fff\"\n           active-text-color=\"#ffd04b\"\n           :collapse-transition=\"false\"\n           :collapse=\"isCollapse\"\n           router\n           @select=\"handleSelect\"\n           class=\"el-menu-vertical-demo\">\n    <div style=\"height: 60px;line-height: 60px;text-align: center\">\n      <img src=\"../assets/logo.png\" alt=\"\" style=\"width:20px;position: relative;top: 3px;margin-right: 5px\">\n      <span style=\"color: white\" v-show=\"logoTextShow\">后台管理系统</span>\n    </div>\n\n    <div v-for=\"item in menus\" :key=\"item.id\">\n      <div v-if=\"item.path\">\n        <el-menu-item :index=\"item.path\">\n          <i :class=\"item.icon\"></i>\n          <span slot=\"title\">{{item.name}}</span>\n        </el-menu-item>\n      </div>\n      <div v-else>\n        <el-submenu :index=\"item.id\">\n          <template slot=\"title\">\n            <i :class=\"item.icon\"></i>\n            <span>{{item.name}}</span>\n          </template>\n          <el-menu-item-group v-for=\"group in item.children\" :key=\"group.id\">\n            <template slot=\"title\">{{group.name}}</template>\n            <el-menu-item v-for=\"menu in group.children\" :key=\"menu.id\" :index=\"menu.path\">\n              <i :class=\"menu.icon\"></i>\n              <span slot=\"title\">{{menu.name}}</span>\n            </el-menu-item>\n          </el-menu-item-group>\n        </el-submenu>\n      </div>\n    </div>\n  </el-menu>\n</template>\n\n<script>\nexport default {\n  name: \"Aside\",\n  props:{\n    isCollapse:Boolean,\n    logoTextShow:Boolean,\n    menus:Array\n  },\n  methods:{\n    handleSelect() {\n      this.$route.fullPath.split(\"/\")\n    }\n  }\n}\n</script>\n\n<style scoped>\n\n</style>"]},"metadata":{},"sourceType":"module"}