{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"File\",\n  data() {\n    return {\n      tableData: [],\n      name: '',\n      multipleSelection: [],\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      total: 0\n    };\n  },\n  created() {\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/file/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.name\n        }\n      }).then(res => {\n        console.log(res);\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      });\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/file/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        });\n        console.log(ids);\n        this.request.post(\"/file/deleteBatch\", ids).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleFileUploadSuccess(res) {\n      console.log(res);\n      this.query();\n    },\n    downLoad(url) {\n      window.open(url);\n    },\n    handleEnable(row) {\n      this.request.post(\"/file/update\", row).then(res => {\n        if (res.code === '200') {\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          });\n        } else {\n          this.$message.error('操作失败');\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","tableData","multipleSelection","headerBg","pageNum","pageSize","total","created","query","methods","handleSizeChange","val","console","log","handleCurrentChange","request","get","params","then","res","records","reset","handleEdit","row","form","dialogFormVisible","handleDelete","id","$confirm","confirmButtonText","cancelButtonText","type","delete","code","$message","message","error","catch","handleSelectionChange","deleteBatch","length","ids","forEach","item","push","post","handleFileUploadSuccess","downLoad","url","window","open","handleEnable"],"sources":["D:\\PycharmProjects\\Agricultural Machinery Operation Data Processing and Analysis Software\\FrontEnd\\src\\views\\File.vue"],"sourcesContent":["<template>\n  <div>\n\n    <div style=\"padding: 10px 0\">\n      <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"name\"></el-input>\n      <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n      <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <div style=\"padding: 10px 0\">\n      <el-upload\n          action=\"http://localhost:8090/file/upload\" :show-file-list=\"false\" accept=\"xlsx\" :on-success=\"handleFileUploadSuccess\" style=\"display: inline-block\"> <!--上传地址-->\n        <el-button type=\"primary\" class=\"ml-5\">上传<i class=\"el-icon-top\"></i> </el-button>\n      </el-upload>\n      <el-button type=\"danger\" @click=\"deleteBatch\" style=\"display:inline-block; margin-left: 10px;\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n\n    </div>\n    <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n      </el-table-column>\n      <el-table-column prop=\"name\" label=\"文件名称\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"type\" label=\"文件类型\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"size\" label=\"文件大小(kb)\" width=\"200\">\n      </el-table-column>\n      <el-table-column  label=\"下载\" width=\"120\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"primary\" @click=\"downLoad(scope.row.url)\">下载\n            <i class=\"el-icon-download\"></i> </el-button>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"启用\">\n        <template slot-scope=\"scope\">\n          <el-switch\n              v-model=\"scope.row.enable\"\n              active-color=\"#13ce66\"\n              inactive-color=\"#ff4949\"\n              @change=\"handleEnable(scope.row)\"\n          >\n          </el-switch>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div style=\"padding: 10px 0\">\n      <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"pageNum\"\n          :page-sizes=\"[5, 10, 15, 20]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n      </el-pagination>\n    </div>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"File\",\n  data(){\n    return{\n      tableData:[],\n      name:'',\n      multipleSelection: [],\n      headerBg: \"headerBg\",\n      pageNum:1,\n      pageSize:5,\n      total:0\n    }\n  },\n  created() {\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/file/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.name,\n        }\n      }).then(res => {\n        console.log(res)\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      })\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/file/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        })\n        console.log(ids);\n        this.request.post(\"/file/deleteBatch\", ids).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleFileUploadSuccess(res) {\n      console.log(res);\n      this.query();\n    },\n    downLoad(url) {\n      window.open(url);\n    },\n    handleEnable(row){\n      this.request.post(\"/file/update\",row).then(res=>{\n        if(res.code==='200'){\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          });\n        }else{\n          this.$message.error('操作失败');\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.headerBg{\n  background: #eee!important;\n}\n</style>"],"mappings":";;;AAkEA,eAAe;EACbA,IAAI,EAAE,MAAM;EACZC,IAAIA,CAAA,EAAE;IACJ,OAAM;MACJC,SAAS,EAAC,EAAE;MACZF,IAAI,EAAC,EAAE;MACPG,iBAAiB,EAAE,EAAE;MACrBC,QAAQ,EAAE,UAAU;MACpBC,OAAO,EAAC,CAAC;MACTC,QAAQ,EAAC,CAAC;MACVC,KAAK,EAAC;IACR;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,KAAK,CAAC,CAAC;EACd,CAAC;EACDC,OAAO,EAAE;IACPC,gBAAgBA,CAACC,GAAG,EAAE;MACpBC,OAAO,CAACC,GAAG,CAAC,MAAMF,GAAG,IAAI,CAAC;MAC1B,IAAI,CAACN,QAAO,GAAIM,GAAG;MACnB,IAAI,CAACP,OAAM,GAAI,CAAC;MAChB,IAAI,CAACI,KAAK,CAAC,CAAC;IACd,CAAC;IACDM,mBAAmBA,CAACH,GAAG,EAAE;MACvBC,OAAO,CAACC,GAAG,CAAC,QAAQF,GAAG,EAAE,CAAC;MAC1B,IAAI,CAACP,OAAM,GAAIO,GAAG;MAClB,IAAI,CAACH,KAAK,CAAC,CAAC;IACd,CAAC;IACDA,KAAKA,CAAA,EAAG;MACN,IAAI,CAACO,OAAO,CAACC,GAAG,CAAC,aAAa,EAAE;QAC9BC,MAAM,EAAE;UACNb,OAAO,EAAE,IAAI,CAACA,OAAO;UACrBC,QAAQ,EAAE,IAAI,CAACA,QAAQ;UACvBN,IAAI,EAAE,IAAI,CAACA;QACb;MACF,CAAC,CAAC,CAACmB,IAAI,CAACC,GAAE,IAAK;QACbP,OAAO,CAACC,GAAG,CAACM,GAAG;QACf,IAAI,CAAClB,SAAQ,GAAIkB,GAAG,CAACnB,IAAI,CAACoB,OAAO;QACjC,IAAI,CAACd,KAAI,GAAIa,GAAG,CAACnB,IAAI,CAACM,KAAK;MAC7B,CAAC;IACH,CAAC;IACDe,KAAKA,CAAA,EAAG;MACN,IAAI,CAACtB,IAAG,GAAI,EAAE;MACd,IAAI,CAACS,KAAK,CAAC,CAAC;IACd,CAAC;IACDc,UAAUA,CAACC,GAAG,EAAE;MACd,IAAI,CAACC,IAAG,GAAID,GAAG;MACf,IAAI,CAACE,iBAAgB,GAAI,IAAI;IAC/B,CAAC;IACDC,YAAYA,CAACC,EAAE,EAAE;MACf,IAAI,CAACC,QAAQ,CAAC,oBAAoB,EAAE,IAAI,EAAE;QACxCC,iBAAiB,EAAE,IAAI;QACvBC,gBAAgB,EAAE,IAAI;QACtBC,IAAI,EAAE;MACR,CAAC,CAAC,CAACb,IAAI,CAAC,MAAM;QACZ,IAAI,CAACH,OAAO,CAACiB,MAAM,CAAC,QAAO,GAAIL,EAAE,CAAC,CAACT,IAAI,CAACC,GAAE,IAAK;UAC7C,IAAIA,GAAG,CAACc,IAAG,KAAM,KAAK,EAAE;YACtB,IAAI,CAACC,QAAQ,CAAC;cACZC,OAAO,EAAE,MAAM;cACfJ,IAAI,EAAE;YACR,CAAC,CAAC;YACF,IAAI,CAACvB,KAAK,CAAC,CAAC;