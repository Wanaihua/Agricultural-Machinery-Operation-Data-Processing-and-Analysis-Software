{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\n// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\nexport default {\n  components: {\n    Aside\n  },\n  data() {\n    const item = {\n      date: '2016-05-02',\n      name: '王小虎',\n      address: '上海市普陀区金沙江路 1518 弄'\n    };\n    return {\n      tableData: Array(10).fill(item),\n      msg: \"hello world\",\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      email: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      form: {}\n    };\n  },\n  created() {\n    //请求分页查询\n    this.query();\n  },\n  methods: {\n    collapse() {\n      this.isCollapsed = !this.isCollapsed;\n      if (this.isCollapsed) {\n        this.sideWidth = 64;\n        this.collapseBtnClass = \"el-icon-s-unfold\";\n        this.logoTextShow = false;\n      } else {\n        this.sideWidth = 200;\n        this.collapseBtnClass = \"el-icon-s-fold\";\n        this.logoTextShow = true;\n      }\n    },\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/user/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          username: this.username,\n          address: this.address,\n          email: this.email\n        }\n      }).then(res => {\n        console.log(res);\n        this.tableData = res.records;\n        this.total = res.total;\n      });\n    },\n    reset() {\n      this.username = \"\";\n      this.address = \"\";\n      this.email = \"\";\n      this.query();\n    },\n    handleAdd() {\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save() {\n      this.dialogFormVisible = false;\n      this.request.post(\"/user\", this.form).then(res => {\n        if (res) {\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        } else {\n          this.$message.error('保存失败');\n        }\n      });\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/user/\" + id).then(res => {\n          if (res) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        });\n        console.log(ids);\n        this.request.post(\"/user/deleteBatch\", ids).then(res => {\n          if (res) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    }\n  }\n};","map":{"version":3,"mappings":";AAiHA;AACA;AACA;AAEA;EACAA;IAAAC;EAAA;EACAC;IACA;MACAC;MACAC;MACAC;IACA;IACA;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAV;MACAW;MACAC;MACAC;MACAC;MACAC;IACA;EACA;EACAC;IACA;IACA;EACA;EACAC;IACAC;MACA;MACA;QACA;QACA;QACA;MACA;QACA;QACA;QACA;MACA;IACA;IACAC;MACAC;MACA;MACA;MACA;IACA;IACAC;MACAD;MACA;MACA;IACA;IACAE;MACA;QACAC;UACAf;UACAC;UACAC;UACAV;UACAW;QACA;MAAA;QACAS;QACA;QACA;MACA;IACA;IACAI;MACA;MACA;MACA;MACA;IACA;IACAC;MACA;MACA;IACA;IACAC;MACA;MACA;QACA;UACA;YACAC;YACAC;UACA;UACA;QACA;UACA;QACA;MACA;IACA;IACAC;MACA;MACA;IACA;IACAC;MACA;QACAC;QACAC;QACAJ;MACA;QACA;UACA;YACA;cACAD;cACAC;YACA;YACA;UACA;YACA;UACA;QACA;MACA;QACA;UACAA;UACAD;QACA;MACA;IACA;IACAM;MACAb;MACA;IACA;IACAc;MACA;QACA;UACAP;UACAC;QACA;QACA;MACA;MACA;QACAG;QACAC;QACAJ;MACA;QACA;QACA;UACAO;QACA;QACAf;QACA;UACA;YACA;cACAO;cACAC;YACA;YACA;UACA;YACA;UACA;QACA;MACA;QACA;UACAA;UACAD;QACA;MACA;IACA;EACA;AACA","names":["components","Aside","data","date","name","address","tableData","msg","collapseBtnClass","isCollapse","sideWidth","logoTextShow","headerBg","pageNum","pageSize","username","email","total","dialogFormVisible","multipleSelection","form","created","methods","collapse","handleSizeChange","console","handleCurrentChange","query","params","reset","handleAdd","save","message","type","handleEdit","handleDelete","confirmButtonText","cancelButtonText","handleSelectionChange","deleteBatch","ids"],"sourceRoot":"src/views","sources":["Manage.vue"],"sourcesContent":["<template>\n  <div style=\"height:100%\">\n    <el-container style=\"min-height: 100vh;\">\n      <el-aside :width=\"sideWidth+'px'\" style=\"background-color: rgb(238,241,246); box-shadow: 2px 0 6px rgb(0 21 41 / 35%)\">\n        <Aside :isCollapse=\"isCollapse\" :logoTextShow=\"logoTextShow\"/>\n      </el-aside>\n\n      <el-container>\n        <el-header style=\"font-size: 12px;border-bottom: 1px solid #ccc;line-height: 60px;display: flex\">\n          <div style=\"flex:1;font-size: 20px\">\n            <span :class=\"collapseBtnClass\" style=\"cursor: pointer\" @click=\"collapse\"></span>\n          </div>\n          <el-dropdown style=\"width: 70px;cursor: pointer\">\n            <span>王小虎</span><i class=\"el-icon-arrow-down\" style=\"margin-left: 5px\"></i>\n            <el-dropdown-menu slot=\"dropdown\">\n              <el-dropdown-item style=\"font-size: 14px;padding: 5px 0\">个人信息</el-dropdown-item>\n              <el-dropdown-item style=\"font-size: 14px;padding: 5px 0\">退出</el-dropdown-item>\n            </el-dropdown-menu>\n          </el-dropdown>\n        </el-header>\n\n        <el-main>\n\n          <div style=\"margin-bottom: 30px\">\n            <el-breadcrumb separator=\"/\">\n              <el-breadcrumb-item :to=\"{ path: '/' }\">首页</el-breadcrumb-item>\n              <el-breadcrumb-item><a href=\"/\">用户管理</a></el-breadcrumb-item>\n            </el-breadcrumb>\n          </div>\n\n\n          <div style=\"padding: 10px 0\">\n            <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"username\"></el-input>\n            <el-input style=\"width: 200px\" placeholder=\"请输入邮箱\" suffix-icon=\"el-icon-message\" v-model=\"email\" class=\"ml-5\"></el-input>\n            <el-input style=\"width: 200px\" placeholder=\"请输入地址\" suffix-icon=\"el-icon-position\" v-model=\"address\" class=\"ml-5\"></el-input>\n            <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n            <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n          </div>\n\n          <div style=\"padding: 10px 0\">\n            <el-button type=\"primary\" @click=\"handleAdd\">新增<i class=\"el-icon-circle-plus-outline\"></i> </el-button>\n            <el-button type=\"danger\" @click=\"deleteBatch\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n            <el-button type=\"primary\">导入<i class=\"el-icon-bottom\"></i> </el-button>\n            <el-button type=\"primary\">导出<i class=\"el-icon-top\"></i> </el-button>\n          </div>\n\n          <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n            <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n            <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n            </el-table-column>\n            <el-table-column prop=\"username\" label=\"姓名\" width=\"120\">\n            </el-table-column>\n            <el-table-column prop=\"nickname\" label=\"昵称\" width=\"120\">\n            </el-table-column>\n            <el-table-column prop=\"email\" label=\"邮箱\" width=\"200\">\n            </el-table-column>\n            <el-table-column prop=\"phone\" label=\"电话\" width=\"120\">\n            </el-table-column>\n            <el-table-column prop=\"address\" label=\"地址\">\n            </el-table-column>\n            <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n              <template slot-scope=\"scope\">\n                <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑<i class=\"el-icon-edit\"></i> </el-button>\n                <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n              </template>\n            </el-table-column>\n          </el-table>\n          <div style=\"padding: 10px 0\">\n            <el-pagination\n                @size-change=\"handleSizeChange\"\n                @current-change=\"handleCurrentChange\"\n                :current-page=\"pageNum\"\n                :page-sizes=\"[5, 10, 15, 20]\"\n                :page-size=\"pageSize\"\n                layout=\"total, sizes, prev, pager, next, jumper\"\n                :total=\"total\">\n            </el-pagination>\n          </div>\n\n          <el-dialog title=\"用户信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\n            <el-form label-width=\"80px\">\n              <el-form-item label=\"\" style=\"display: none\">\n                <el-input v-model=\"form.id\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"用户名\">\n                <el-input v-model=\"form.username\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"昵称\">\n                <el-input v-model=\"form.nickname\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"电话\">\n                <el-input v-model=\"form.phone\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"邮箱\">\n                <el-input v-model=\"form.email\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n              <el-form-item label=\"地址\">\n                <el-input v-model=\"form.address\" autocomplete=\"off\"></el-input>\n              </el-form-item>\n            </el-form>\n            <div slot=\"footer\" class=\"dialog-footer\">\n              <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n              <el-button type=\"primary\" @click=\"save()\">确 定</el-button>\n            </div>\n          </el-dialog>\n\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\n// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\n\nexport default {\n  components: {Aside},\n  data() {\n     const item = {\n            date: '2016-05-02',\n            name: '王小虎',\n            address: '上海市普陀区金沙江路 1518 弄'\n          };\n          return {\n            tableData: Array(10).fill(item),\n            msg:\"hello world\",\n            collapseBtnClass:\"el-icon-s-fold\",\n            isCollapse:false,\n            sideWidth:200,\n            logoTextShow:true,\n            headerBg:\"headerBg\",\n            pageNum:1,\n            pageSize:5,\n            username:\"\",\n            address: \"\",\n            email: \"\",\n            total:0,\n            dialogFormVisible: false,\n            multipleSelection: [],\n            form: {}\n          }\n  },\n  created() {\n    //请求分页查询\n    this.query();\n  },\n  methods:{\n    collapse(){\n      this.isCollapsed = !this.isCollapsed;\n      if(this.isCollapsed){\n        this.sideWidth = 64;\n        this.collapseBtnClass=\"el-icon-s-unfold\"\n        this.logoTextShow = false\n      }else{\n        this.sideWidth = 200;\n        this.collapseBtnClass=\"el-icon-s-fold\"\n        this.logoTextShow = true\n      }\n    },\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize=val;\n      this.pageNum=1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum=val;\n      this.query();\n    },\n    query(){\n      this.request.get(\"/user/page?\",{\n        params:{\n          pageNum:this.pageNum,\n          pageSize:this.pageSize,\n          username:this.username,\n          address:this.address,\n          email:this.email\n        }}).then(res=>{\n          console.log(res)\n          this.tableData = res.records;\n          this.total=res.total;\n      })\n    },\n    reset() {\n      this.username = \"\";\n      this.address = \"\";\n      this.email = \"\";\n      this.query();\n    },\n    handleAdd(){\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save(){\n      this.dialogFormVisible = false;\n      this.request.post(\"/user\",this.form).then(res=>{\n        if(res){\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        }else {\n          this.$message.error('保存失败');\n        }\n      })\n    },\n    handleEdit(row){\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id){\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/user/\"+id).then(res=>{\n          if(res){\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          }else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val){\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch(){\n      if(this.multipleSelection.length==0){\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item=>{\n          ids.push(item.id);\n        })\n        console.log(ids);\n        this.request.post(\"/user/deleteBatch\",ids).then(res=>{\n          if(res){\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          }else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    }\n  }\n}\n</script>\n<style>\n.headerBg{\n  background: #eee!important;\n}\n.el-menu-vertical-demo:not(.el-menu--collapse){\n  width: 200px;\n  height: 100%;\n}\n.el-menu-vertical-demo{\n  transition: width 1s;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}