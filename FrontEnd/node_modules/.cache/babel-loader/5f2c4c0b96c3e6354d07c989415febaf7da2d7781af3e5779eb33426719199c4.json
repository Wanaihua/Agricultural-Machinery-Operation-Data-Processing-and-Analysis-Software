{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'LoginPage',\n  data() {\n    return {\n      form: {\n        username: '',\n        password: ''\n      },\n      loading: false,\n      result: null\n    };\n  },\n  computed: {\n    formattedResult() {\n      return JSON.stringify(this.result, null, 2);\n    }\n  },\n  methods: {\n    async submitLogin() {\n      this.loading = true;\n      this.result = null;\n      try {\n        const response = await axios.post('http://127.0.0.1:8000/api/login-test/', {\n          username: this.form.username,\n          password: this.form.password\n        });\n        this.result = {\n          status: response.status,\n          data: response.data\n        };\n      } catch (error) {\n        if (error.response) {\n          this.result = {\n            status: error.response.status,\n            data: error.response.data\n          };\n        } else {\n          this.result = {\n            status: 0,\n            data: {\n              message: error.message\n            }\n          };\n        }\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","name","data","form","username","password","loading","result","computed","formattedResult","JSON","stringify","methods","submitLogin","response","post","status","error","message"],"sources":["D:\\PycharmProjects\\Agricultural Machinery Operation Data Processing and Analysis Software\\FrontEnd\\src\\views\\login\\LoginPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"login-page\">\r\n    <div class=\"login-card\">\r\n      <h1>Login Test</h1>\r\n      <p class=\"subtitle\">Test POST /api/login-test/ from Vue</p>\r\n\r\n      <form @submit.prevent=\"submitLogin\">\r\n        <label for=\"username\">Username</label>\r\n        <input id=\"username\" v-model.trim=\"form.username\" type=\"text\" placeholder=\"Enter username\" />\r\n\r\n        <label for=\"password\">Password</label>\r\n        <input id=\"password\" v-model=\"form.password\" type=\"password\" placeholder=\"Enter password\" />\r\n\r\n        <button type=\"submit\" :disabled=\"loading\">\r\n          {{ loading ? 'Submitting...' : 'Login Test' }}\r\n        </button>\r\n      </form>\r\n\r\n      <p class=\"hint\">Backend endpoint: http://127.0.0.1:8000/api/login-test/</p>\r\n\r\n      <div v-if=\"result\" class=\"result\">\r\n        <h2>Result</h2>\r\n        <pre>{{ formattedResult }}</pre>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\n\r\nexport default {\r\n  name: 'LoginPage',\r\n  data() {\r\n    return {\r\n      form: {\r\n        username: '',\r\n        password: '',\r\n      },\r\n      loading: false,\r\n      result: null,\r\n    }\r\n  },\r\n  computed: {\r\n    formattedResult() {\r\n      return JSON.stringify(this.result, null, 2)\r\n    },\r\n  },\r\n  methods: {\r\n    async submitLogin() {\r\n      this.loading = true\r\n      this.result = null\r\n      try {\r\n        const response = await axios.post('http://127.0.0.1:8000/api/login-test/', {\r\n          username: this.form.username,\r\n          password: this.form.password,\r\n        })\r\n        this.result = {\r\n          status: response.status,\r\n          data: response.data,\r\n        }\r\n      } catch (error) {\r\n        if (error.response) {\r\n          this.result = {\r\n            status: error.response.status,\r\n            data: error.response.data,\r\n          }\r\n        } else {\r\n          this.result = {\r\n            status: 0,\r\n            data: { message: error.message },\r\n          }\r\n        }\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n  },\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-page {\r\n  min-height: 100vh;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  background: linear-gradient(135deg, #f4f7fb 0%, #dde8f5 100%);\r\n  padding: 24px;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.login-card {\r\n  width: 100%;\r\n  max-width: 420px;\r\n  background: #ffffff;\r\n  border-radius: 14px;\r\n  padding: 24px;\r\n  box-shadow: 0 12px 30px rgba(35, 60, 90, 0.15);\r\n}\r\n\r\nh1 {\r\n  margin: 0 0 8px;\r\n  font-size: 26px;\r\n}\r\n\r\n.subtitle {\r\n  margin: 0 0 20px;\r\n  color: #5b6677;\r\n}\r\n\r\nlabel {\r\n  display: block;\r\n  margin: 10px 0 6px;\r\n  font-weight: 600;\r\n}\r\n\r\ninput {\r\n  width: 100%;\r\n  box-sizing: border-box;\r\n  padding: 10px 12px;\r\n  border: 1px solid #c7d2e2;\r\n  border-radius: 8px;\r\n  font-size: 14px;\r\n}\r\n\r\nbutton {\r\n  margin-top: 14px;\r\n  width: 100%;\r\n  padding: 10px 12px;\r\n  border: none;\r\n  border-radius: 8px;\r\n  background: #1f6feb;\r\n  color: #fff;\r\n  font-size: 15px;\r\n  cursor: pointer;\r\n}\r\n\r\nbutton:disabled {\r\n  opacity: 0.65;\r\n  cursor: not-allowed;\r\n}\r\n\r\n.hint {\r\n  margin-top: 14px;\r\n  color: #6a7485;\r\n  font-size: 13px;\r\n}\r\n\r\n.result {\r\n  margin-top: 18px;\r\n  background: #f7f9fc;\r\n  border: 1px solid #dde6f1;\r\n  border-radius: 8px;\r\n  padding: 12px;\r\n}\r\n\r\nh2 {\r\n  margin: 0 0 8px;\r\n  font-size: 17px;\r\n}\r\n\r\npre {\r\n  margin: 0;\r\n  white-space: pre-wrap;\r\n  word-break: break-word;\r\n}\r\n</style>\r\n"],"mappings":"AA6BA,OAAOA,KAAI,MAAO,OAAM;AAExB,eAAe;EACbC,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;QACJC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE;MACZ,CAAC;MACDC,OAAO,EAAE,KAAK;MACdC,MAAM,EAAE;IACV;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,eAAeA,CAAA,EAAG;MAChB,OAAOC,IAAI,CAACC,SAAS,CAAC,IAAI,CAACJ,MAAM,EAAE,IAAI,EAAE,CAAC;IAC5C;EACF,CAAC;EACDK,OAAO,EAAE;IACP,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI,CAACP,OAAM,GAAI,IAAG;MAClB,IAAI,CAACC,MAAK,GAAI,IAAG;MACjB,IAAI;QACF,MAAMO,QAAO,GAAI,MAAMd,KAAK,CAACe,IAAI,CAAC,uCAAuC,EAAE;UACzEX,QAAQ,EAAE,IAAI,CAACD,IAAI,CAACC,QAAQ;UAC5BC,QAAQ,EAAE,IAAI,CAACF,IAAI,CAACE;QACtB,CAAC;QACD,IAAI,CAACE,MAAK,GAAI;UACZS,MAAM,EAAEF,QAAQ,CAACE,MAAM;UAC