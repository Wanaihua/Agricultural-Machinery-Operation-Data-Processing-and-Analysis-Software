{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"User\",\n  data() {\n    return {\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      email: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      tableData: [],\n      form: {},\n      roles: []\n    };\n  },\n  created() {\n    //分页查询\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/user/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          username: this.username,\n          address: this.address,\n          email: this.email\n        }\n      }).then(res => {\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      });\n      this.request.get(\"/role\").then(res => {\n        this.roles = res.data;\n      });\n    },\n    reset() {\n      this.username = \"\";\n      this.address = \"\";\n      this.email = \"\";\n      this.query();\n    },\n    handleAdd() {\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save() {\n      this.dialogFormVisible = false;\n      this.request.post(\"/user\", this.form).then(res => {\n        if (res.code === '200') {\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        } else {\n          this.$message.error('保存失败');\n        }\n      });\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/user/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        });\n        console.log(ids);\n        this.request.post(\"/user/deleteBatch\", ids).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    exp() {\n      this.$confirm('此操作将导出用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        window.open(\"http://localhost:8090/user/export\");\n        this.$message({\n          message: '导出成功',\n          type: 'success'\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消导出'\n        });\n      });\n    },\n    handleExcelImportSuccess() {\n      this.$message({\n        message: '导入成功',\n        type: 'success'\n      });\n      this.query();\n    }\n  }\n};","map":{"version":3,"names":["name","data","collapseBtnClass","isCollapse","sideWidth","logoTextShow","headerBg","pageNum","pageSize","username","address","email","total","dialogFormVisible","multipleSelection","tableData","form","roles","created","query","methods","handleSizeChange","val","console","log","handleCurrentChange","request","get","params","then","res","records","reset","handleAdd","save","post","code","$message","message","type","error","handleEdit","row","handleDelete","id","$confirm","confirmButtonText","cancelButtonText","delete","catch","handleSelectionChange","deleteBatch","length","ids","forEach","item","push","exp","window","open","handleExcelImportSuccess"],"sources":["src/views/User.vue"],"sourcesContent":["<template>\n  <div>\n\n    <div style=\"padding: 10px 0\">\n      <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"username\"></el-input>\n      <el-input style=\"width: 200px\" placeholder=\"请输入邮箱\" suffix-icon=\"el-icon-message\" v-model=\"email\" class=\"ml-5\"></el-input>\n      <el-input style=\"width: 200px\" placeholder=\"请输入地址\" suffix-icon=\"el-icon-position\" v-model=\"address\" class=\"ml-5\"></el-input>\n      <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n      <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <div style=\"padding: 10px 0\">\n      <el-button type=\"primary\" @click=\"handleAdd\">新增<i class=\"el-icon-circle-plus-outline\"></i> </el-button>\n      <el-button type=\"danger\" @click=\"deleteBatch\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n      <el-upload\n          action=\"http://localhost:8090/user/import\" :show-file-list=\"false\" accept=\"xlsx\" :on-success=\"handleExcelImportSuccess\" style=\"display: inline-block\"> <!--上传地址-->\n      <el-button type=\"primary\" class=\"ml-5\">导入<i class=\"el-icon-bottom\"></i> </el-button>\n      </el-upload>\n      <el-button type=\"primary\" @click=\"exp\" class=\"ml-5\">导出<i class=\"el-icon-top\"></i> </el-button>\n    </div>\n\n    <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n      </el-table-column>\n      <el-table-column prop=\"username\" label=\"姓名\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"role\" label=\"角色\">\n      </el-table-column>\n      <el-table-column prop=\"nickname\" label=\"昵称\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"email\" label=\"邮箱\" width=\"200\">\n      </el-table-column>\n      <el-table-column prop=\"phone\" label=\"电话\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"address\" label=\"地址\">\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n      <template slot-scope=\"scope\">\n          <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑<i class=\"el-icon-edit\"></i> </el-button>\n          <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div style=\"padding: 10px 0\">\n      <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"pageNum\"\n          :page-sizes=\"[5, 10, 15, 20]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n      </el-pagination>\n    </div>\n\n    <el-dialog title=\"用户信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\n      <el-form label-width=\"80px\">\n        <el-form-item label=\"\" style=\"display: none\">\n          <el-input v-model=\"form.id\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"用户名\">\n          <el-input v-model=\"form.username\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"角色\">\n          <el-select clearable v-model=\"form.role\" placeholder=\"请选择角色\" style=\"width: 100%\">\n            <el-option\n                v-for=\"item in roles\"\n                :key=\"item.name\"\n                :label=\"item.name\"\n                :value=\"item.flag\">\n            </el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"昵称\">\n          <el-input v-model=\"form.nickname\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"电话\">\n          <el-input v-model=\"form.phone\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"邮箱\">\n          <el-input v-model=\"form.email\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"地址\">\n          <el-input v-model=\"form.address\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save()\">确 定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"User\",\n  data() {\n    return {\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      email: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      tableData: [],\n      form:{},\n      roles:[]\n    }\n  },\n  created() {\n    //分页查询\n    this.query();\n  },\n  methods:{\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize=val;\n      this.pageNum=1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum=val;\n      this.query();\n    },\n    query(){\n      this.request.get(\"/user/page?\",{\n        params:{\n          pageNum:this.pageNum,\n          pageSize:this.pageSize,\n          username:this.username,\n          address:this.address,\n          email:this.email\n        }}).then(res=>{\n        this.tableData = res.data.records;\n        this.total=res.data.total;\n      })\n      this.request.get(\"/role\").then(res=>{\n        this.roles=res.data;\n      })\n    },\n    reset() {\n      this.username = \"\";\n      this.address = \"\";\n      this.email = \"\";\n      this.query();\n    },\n    handleAdd(){\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save(){\n      this.dialogFormVisible = false;\n      this.request.post(\"/user\",this.form).then(res=>{\n        if(res.code==='200'){\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        }else {\n          this.$message.error('保存失败');\n        }\n      })\n    },\n    handleEdit(row){\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id){\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/user/\"+id).then(res=>{\n          if(res.code==='200'){\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          }else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val){\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        })\n        console.log(ids);\n        this.request.post(\"/user/deleteBatch\", ids).then(res => {\n          if (res.code==='200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    exp(){\n      this.$confirm('此操作将导出用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n\n        window.open(\"http://localhost:8090/user/export\");\n        this.$message({\n          message: '导出成功',\n          type: 'success'\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消导出'\n        });\n      });\n    },\n    handleExcelImportSuccess(){\n      this.$message({\n        message: '导入成功',\n        type: 'success'\n      });\n      this.query();\n    },\n  }\n}\n</script>\n\n<style>\n.headerBg{\n  background: #eee!important;\n}\n.el-menu-vertical-demo:not(.el-menu--collapse){\n  width: 200px;\n  height: 100%;\n}\n.el-menu-vertical-demo{\n  transition: width 1s;\n}\n</style>\n"],"mappings":";;;AAgGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,gBAAA;MACAC,UAAA;MACAC,SAAA;MACAC,YAAA;MACAC,QAAA;MACAC,OAAA;MACAC,QAAA;MACAC,QAAA;MACAC,OAAA;MACAC,KAAA;MACAC,KAAA;MACAC,iBAAA;MACAC,iBAAA;MACAC,SAAA;MACAC,IAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAAC,KAAA;EACA;EACAC,OAAA;IACAC,iBAAAC,GAAA;MACAC,OAAA,CAAAC,GAAA,OAAAF,GAAA;MACA,KAAAd,QAAA,GAAAc,GAAA;MACA,KAAAf,OAAA;MACA,KAAAY,KAAA;IACA;IACAM,oBAAAH,GAAA;MACAC,OAAA,CAAAC,GAAA,SAAAF,GAAA;MACA,KAAAf,OAAA,GAAAe,GAAA;MACA,KAAAH,KAAA;IACA;IACAA,MAAA;MACA,KAAAO,OAAA,CAAAC,GAAA;QACAC,MAAA;UACArB,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAC,QAAA,OAAAA,QAAA;UACAC,OAAA,OAAAA,OAAA;UACAC,KAAA,OAAAA;QACA;MAAA,GAAAkB,IAAA,CAAAC,GAAA;QACA,KAAAf,SAAA,GAAAe,GAAA,CAAA7B,IAAA,CAAA8B,OAAA;QACA,KAAAnB,KAAA,GAAAkB,GAAA,CAAA7B,IAAA,CAAAW,KAAA;MACA;MACA,KAAAc,OAAA,CAAAC,GAAA,UAAAE,IAAA,CAAAC,GAAA;QACA,KAAAb,KAAA,GAAAa,GAAA,CAAA7B,IAAA;MACA;IACA;IACA+B,MAAA;MACA,KAAAvB,QAAA;MACA,KAAAC,OAAA;MACA,KAAAC,KAAA;MACA,KAAAQ,KAAA;IACA;IACAc,UAAA;MACA,KAAApB,iBAAA;MACA,KAAAG,IAAA;IACA;IACAkB,KAAA;MACA,KAAArB,iBAAA;MACA,KAAAa,OAAA,CAAAS,IAAA,eAAAnB,IAAA,EAAAa,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAM,IAAA;UACA,KAAAC,QAAA;YACAC,OAAA;YACAC,IAAA;UACA;UACA,KAAApB,KAAA;QACA;UACA,KAAAkB,QAAA,CAAAG,KAAA;QACA;MACA;IACA;IACAC,WAAAC,GAAA;MACA,KAAA1B,IAAA,GAAA0B,GAAA;MACA,KAAA7B,iBAAA;IACA;IACA8B,aAAAC,EAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAR,IAAA;MACA,GAAAV,IAAA;QACA,KAAAH,OAAA,CAAAsB,MAAA,YAAAJ,EAAA,EAAAf,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAM,IAAA;YACA,KAAAC,QAAA;cACAC,OAAA;cACAC,IAAA;YACA;YACA,KAAApB,KAAA;UACA;YACA,KAAAkB,QAAA,CAAAG,KAAA;UACA;QACA;MACA,GAAAS,KAAA;QACA,KAAAZ,QAAA;UACAE,IAAA;UACAD,OAAA;QACA;MACA;IACA;IAC