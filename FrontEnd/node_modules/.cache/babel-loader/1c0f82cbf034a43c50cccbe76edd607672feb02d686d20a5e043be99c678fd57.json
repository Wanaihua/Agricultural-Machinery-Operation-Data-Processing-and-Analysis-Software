{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: \"Home\",\n  data() {\n    return {};\n  },\n  mounted() {\n    //页面元素加载完成后执行\n\n    var option, pie;\n    option = {\n      title: {\n        text: '各季度会员数量统计',\n        subtext: '趋势图',\n        left: 'center'\n      },\n      tooltip: {\n        trigger: 'item'\n      },\n      legend: {\n        orient: 'vertical',\n        left: 'left'\n      },\n      xAxis: {\n        type: 'category',\n        data: [\"第一季度\", \"第二季度\", \"第三季度\", \"第四季度\"]\n      },\n      yAxis: {\n        type: 'value'\n      },\n      series: [{\n        name: '星巴克',\n        data: [],\n        type: 'line'\n      }, {\n        name: '星巴克',\n        data: [],\n        type: 'bar'\n      }, {\n        name: '瑞幸咖啡',\n        data: [],\n        type: 'bar'\n      }, {\n        name: '瑞幸咖啡',\n        data: [],\n        type: 'line'\n      }]\n    };\n    var chartDom = document.getElementById('main');\n    var myChart = echarts.init(chartDom);\n    var pieDom = document.getElementById('pie');\n    var pieChart = echarts.init(pieDom);\n    this.request.get(\"/echarts/members\").then(res => {\n      //填空\n      //  option.xAxis.data=res.data.x;\n      option.series[0].data = res.data;\n      option.series[1].data = res.data;\n      option.series[2].data = [5, 6, 7, 8];\n      option.series[3].data = [5, 6, 7, 8];\n      //数据准备完毕，开始绘制图表\n      myChart.setOption(option);\n      pie.series[0].data = [{\n        name: \"第一季度\",\n        value: res.data[0]\n      }, {\n        name: \"第二季度\",\n        value: res.data[1]\n      }, {\n        name: \"第三季度\",\n        value: res.data[2]\n      }, {\n        name: \"第四季度\",\n        value: res.data[3]\n      }];\n      pieChart.setOption(pie);\n    });\n\n    //饼图\n    pie = {\n      title: {\n        text: '各季度会员数量统计',\n        subtext: '比例图',\n        left: 'center'\n      },\n      tooltip: {\n        trigger: 'item',\n        formatter: \"{a} <br/>{b}: {c} ({d}%)\"\n      },\n      legend: {\n        orient: 'vertical',\n        left: 'left'\n      },\n      series: [{\n        name: '星巴克',\n        type: 'pie',\n        radius: '50%',\n        center: ['30%', '50%'],\n        label: {\n          type: 'pie',\n          radius: '60%',\n          label: {\n            //饼图图形上的文本标签\n            normal: {\n              show: true,\n              position: 'inner',\n              //标签的位置\n              textStyle: {\n                fontWeight: 300,\n                fontSize: 16,\n                //文字的字体大小\n                color: '#fff'\n              },\n              formatter: '{b}:{d}%'\n            }\n          }\n        },\n        data: []\n      }, {\n        name: \"瑞幸咖啡\",\n        type: 'pie',\n        radius: '50%',\n        center: ['65%', '50%'],\n        label: {\n          type: 'pie',\n          radius: '60%',\n          label: {\n            //饼图图形上的文本标签\n            normal: {\n              show: true,\n              position: 'inner',\n              //标签的位置\n              textStyle: {\n                fontWeight: 300,\n                fontSize: 16,\n                //文字的字体大小\n                color: '#fff'\n              },\n              formatter: '{b}:{d}%'\n            }\n          }\n        },\n        data: [{\n          name: \"第一季度\",\n          value: 5\n        }, {\n          name: \"第二季度\",\n          value: 6\n        }, {\n          name: \"第三季度\",\n          value: 7\n        }, {\n          name: \"第四季度\",\n          value: 8\n        }]\n      }]\n    };\n    pie && pieChart.setOption(pie);\n  }\n};","map":{"version":3,"names":["echarts","name","data","mounted","option","pie","title","text","subtext","left","tooltip","trigger","legend","orient","xAxis","type","yAxis","series","chartDom","document","getElementById","myChart","init","pieDom","pieChart","request","get","then","res","setOption","value","formatter","radius","center","label","normal","show","position","textStyle","fontWeight","fontSize","color"],"sources":["D:\\PycharmProjects\\Agricultural Machinery Operation Data Processing and Analysis Software\\FrontEnd\\src\\views\\Home.vue"],"sourcesContent":["<template>\n  <div>\n    <el-row :gutter=\"10\" style=\"margin-buttom:40px\">\n      <el-col :span=\"6\">\n        <el-card  style=\"color: #409EFF\">\n          <div><i class=\"el-icon-user-solid\"></i>用户总数</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            100\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #F56C6C\">\n          <div><i class=\"el-icon-money\"></i>销售总量</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            ￥ 1000000\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #67C23A\">\n          <div><i class=\"el-icon-bank-card\"></i>收益总额</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            ￥ 3000000\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #E6A23C\">\n          <div><i class=\"el-icon-s-shop\"></i>门店总数</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            300\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n    <el-row style=\"margin-top: 50px;\">\n      <el-col :span=\"12\">\n        <div id=\"main\" style=\"width: 500px;height: 450px;\"></div>\n      </el-col>\n\n      <el-col :span=\"12\">\n        <div id=\"pie\" style=\"width: 1000px;height: 400px;\"></div>\n      </el-col>\n    </el-row>\n\n\n\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: \"Home\",\n  data(){\n    return{\n\n    }\n  },\n  mounted() {  //页面元素加载完成后执行\n\n    var option,pie;\n\n    option = {\n      title: {\n        text: '各季度会员数量统计',\n        subtext: '趋势图',\n        left: 'center'\n      },\n      tooltip: {\n        trigger: 'item'\n      },\n      legend: {\n        orient: 'vertical',\n        left: 'left'\n      },\n      xAxis: {\n        type: 'category',\n        data: [\"第一季度\", \"第二季度\", \"第三季度\", \"第四季度\"]\n      },\n      yAxis: {\n        type: 'value'\n      },\n      series: [\n        {\n          name:'星巴克',\n          data: [],\n          type: 'line'\n        },\n        {\n          name:'星巴克',\n          data: [],\n          type: 'bar'\n        },\n        {\n          name:'瑞幸咖啡',\n          data: [],\n          type: 'bar'\n        },\n        {\n          name:'瑞幸咖啡',\n          data: [],\n          type: 'line'\n        }\n      ]\n    };\n\n    var chartDom = document.getElementById('main');\n    var myChart = echarts.init(chartDom);\n    var pieDom = document.getElementById('pie');\n    var pieChart = echarts.init(pieDom);\n\n    this.request.get(\"/echarts/members\").then(res =>{\n      //填空\n    //  option.xAxis.data=res.data.x;\n      option.series[0].data=res.data;\n      option.series[1].data=res.data;\n      option.series[2].data=[5,6,7,8];\n      option.series[3].data=[5,6,7,8];\n      //数据准备完毕，开始绘制图表\n      myChart.setOption(option);\n\n      pie.series[0].data=[\n        {name:\"第一季度\",value:res.data[0]},\n        {name:\"第二季度\",value:res.data[1]},\n        {name:\"第三季度\",value:res.data[2]},\n        {name:\"第四季度\",value:res.data[3]}\n      ]\n      pieChart.setOption(pie);\n    })\n\n\n    //饼图\n    pie = {\n      title: {\n        text: '各季度会员数量统计',\n        subtext: '比例图',\n        left: 'center'\n      },\n      tooltip: {\n        trigger: 'item',\n        formatter: \"{a} <br/>{b}: {c} ({d}%)\"\n      },\n      legend: {\n        orient: 'vertical',\n        left: 'left'\n      },\n      series: [\n        {\n          name:'星巴克',\n          type: 'pie',\n          radius: '50%',\n          center: ['30%', '50%'],\n          label:{\n            type:'pie',\n            radius:'60%',\n            label:{             //饼图图形上的文本标签\n              normal:{\n                show:true,\n                position:'inner',  //标签的位置\n                textStyle:{\n                  fontWeight:300,\n                  fontSize:16,       //文字的字体大小\n                  color:'#fff'\n                },\n                formatter:'{b}:{d}%'\n              }\n            }\n          },\n          data: [],\n        },\n        {\n          name:\"瑞幸咖啡\",\n          type: 'pie',\n          radius: '50%',\n          center: ['65%', '50%'],\n          label:{\n            type:'pie',\n            radius:'60%',\n            label:{             //饼图图形上的文本标签\n              normal:{\n                show:true,\n                position:'inner',  //标签的位置\n                textStyle:{\n                  fontWeight:300,\n                  fontSize:16,       //文字的字体大小\n                  color:'#fff'\n                },\n                formatter:'{b}:{d}%'\n              }\n            }\n          },\n          data: [\n            {name:\"第一季度\",value:5},\n            {name:\"第二季度\",value:6},\n            {name:\"第三季度\",value:7},\n            {name:\"第四季度\",value:8}\n          ],\n        }\n      ]\n    };\n    pie && pieChart.setOption(pie);\n\n  },\n\n}\n</script>\n\n<style scoped>\n\n</style>"],"mappings":"AAoDA,OAAO,KAAKA,OAAM,MAAO,SAAS;AAElC,eAAe;EACbC,IAAI,EAAE,MAAM;EACZC,IAAIA,CAAA,EAAE;IACJ,OAAM,CAEN;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IAAG;;IAEX,IAAIC,MAAM,EAACC,GAAG;IAEdD,MAAK,GAAI;MACPE,KAAK,EAAE;QACLC,IAAI,EAAE,WAAW;QACjBC,OAAO,EAAE,KAAK;QACdC,IAAI,EAAE;MACR,CAAC;MACDC,OAAO,EAAE;QACPC,OAAO,EAAE;MACX,CAAC;MACDC,MAAM,EAAE;QACNC,MAAM,EAAE,UAAU;QAClBJ,IAAI,EAAE;MACR,CAAC;MACDK,KAAK,EAAE;QACLC,IAAI,EAAE,UAAU;QAChBb,IAAI,EAAE,CAAC,MAAM,EAAE,MAAM,EAAE,MAAM,EAAE,MAAM;MACvC,CAAC;MACDc,KAAK,EAAE;QACLD,IAAI,EAAE;MACR,CAAC;MACDE,MAAM,EAAE,CACN;QACEhB,IAAI,EAAC,KAAK;QACVC,IAAI,EAAE,EAAE;QACRa,IAAI,EAAE;MACR,CAAC,EACD;QACEd,IAAI,EAAC,KAAK;QACVC,IAAI,EAAE,EAAE;QACRa,IAAI,E