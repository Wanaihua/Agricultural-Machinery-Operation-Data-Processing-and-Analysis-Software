{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"Header\",\n  props: {\n    collapseBtnClass: String,\n    collapse: Boolean\n  },\n  computed: {\n    currentPathName() {\n      return this.$store.state.currentPathName; //需要监听的路径\n    }\n  },\n\n  watch: {\n    currentPathName(newVal, oldVal) {\n      console.log(newVal);\n    }\n  },\n  data() {\n    return {\n      user: localStorage.getItem('user') ? JSON.parse(localStorage.getItem('user')) : {}\n    };\n  },\n  methods: {\n    collapse() {\n      this.$emit('collapse');\n    },\n    logout() {\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n      this.$message({\n        message: '退出成功',\n        type: 'success'\n      });\n    }\n  }\n};","map":{"version":3,"mappings":";AAgCA;EACAA;EACAC;IACAC;IACAC;EACA;EACAC;IACAC;MACA;IACA;EACA;;EACAC;IACAD;MACAE;IACA;EACA;EACAC;IACA;MACAC;IACA;EACA;EACAC;IACAP;MACA;IACA;IACAQ;MACAC;MACA;MACA;QACAC;QACAC;MACA;IACA;EACA;AAEA","names":["name","props","collapseBtnClass","collapse","computed","currentPathName","watch","console","data","user","methods","logout","localStorage","message","type"],"sourceRoot":"src/components","sources":["Header.vue"],"sourcesContent":["<template>\n  <div style=\"font-size: 12px;line-height: 60px;display: flex\">\n\n    <div style=\"flex:1;font-size: 20px\">\n      <span :class=\"collapseBtnClass\" style=\"cursor: pointer;font-size: 18px;\" @click=\"collapse\"></span>\n\n      <el-breadcrumb separator=\"/\" style=\"display: inline-block; margin-left:10px; \">\n        <el-breadcrumb-item :to=\"'/'\">首页</el-breadcrumb-item>\n        <el-breadcrumb-item>{{currentPathName}}</el-breadcrumb-item>\n      </el-breadcrumb>\n    </div>\n\n\n    <el-dropdown style=\"width: 100px;cursor: pointer\">\n      <div style=\"display: inline-block\">\n        <img :src=\"user.avatarUrl\" alt=\"\" style=\"width: 30px;border-radius: 50%;position: relative;top: 10px;right: 5px\">\n        <span>{{user.nickname}}</span>\n        <i class=\"el-icon-arrow-down\" style=\"margin-left: 5px\"></i>\n      </div>\n\n      <el-dropdown-menu slot=\"dropdown\" style=\"height: 70px; width: 80px;text-align: center\">\n        <el-dropdown-item style=\"font-size: 14px;padding: 5px 0 0 0px;color: #666666;\">个人信息</el-dropdown-item>\n        <el-dropdown-item style=\"font-size: 14px;padding: 5px 5px 0 0px;\">\n          <span style=\"text-decoration: none;\" @click=\"logout\">退出</span>\n        </el-dropdown-item>\n      </el-dropdown-menu>\n    </el-dropdown>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Header\",\n  props:{\n    collapseBtnClass:String,\n    collapse:Boolean,\n  },\n  computed:{\n    currentPathName(){\n      return this.$store.state.currentPathName; //需要监听的路径\n    }\n  },\n  watch:{\n     currentPathName(newVal,oldVal){\n       console.log(newVal)\n     }\n  },\n  data(){\n    return {\n        user: localStorage.getItem('user') ? JSON.parse(localStorage.getItem('user')) : {},\n    }\n  },\n  methods:{\n    collapse(){\n      this.$emit('collapse')\n    },\n    logout(){\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n      this.$message({\n        message: '退出成功',\n        type: 'success'\n      });\n    }\n  }\n\n}\n</script>\n\n<style scoped>\n\n</style>"]},"metadata":{},"sourceType":"module"}