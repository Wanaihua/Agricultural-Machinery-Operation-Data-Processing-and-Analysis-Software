msg);\n            }\n          })\n        }\n      });\n    }\n  }\n}\n</script>\n<style>\n .wrapper {\n   height: 100vh;\n   background-image: linear-gradient(to bottom right, #FC466B, #3F5EFB);\n   overflow: hidden;\n}\n</style>"],"mappings":";AAqBA,SAAQA,SAAS,QAAO,UAAU;AAElC,eAAe;EACbC,IAAI,EAAE,OAAO;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE,CACN,CAAC;MACDC,KAAK,EAAE;QACLC,QAAQ,EAAE,CACR;UAAEC,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,QAAQ;UAAEC,OAAO,EAAE;QAAO,CAAC,EACtD;UAAEC,GAAG,EAAE,CAAC;UAAEC,GAAG,EAAE,CAAC;UAAEH,OAAO,EAAE,eAAe;UAAEC,OAAO,EAAE;QAAO,EAC7D;QACDG,QAAQ,EAAE,CACR;UAAEL,QAAQ,EAAE,IAAI;UAAEC,OAAO,EAAE,OAAO;UAAEC,OAAO,EAAE;QAAO;MAExD;IACF;EACF,CAAC;EACDI,OAAO,EAAE;IACPC,KAAKA,CAAA,EAAG;MACN,IAAI,CAACC,KAAK,CAAC,UAAU,CAAC,CAACC,QAAQ,CAAEC,KAAK,IAAK;QACzC,IAAIA,KAAK,EAAE;UACT,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,aAAa,EAAE,IAAI,CAACf,IAAI,CAAC,CAACgB,IAAI,CAACC,GAAE,IAAK;YACtD,IAAIA,GAAG,CAACC,IAAI,KAAG,KAAK,EAAE;cACpBC,YAAY,CAACC,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAACL,GAAG,CAAClB,IAAI,CAAC,GAAE;cACvDoB,YAAY,CAACC,OAAO,CAAC,OAAO,EAACC,IAAI,CAACC,SAAS,CAACL,GAAG,CAAClB,IAAI,CAACwB,KAAK,CAAC,GAAE;cAC7D;cACA1B,SAAS,CAAC,CAAC;cACX,IAAI,CAAC2B,QAAQ,CAAC;gBACZpB,OAAO,EAAE,MAAM;gBACfqB,IAAI,EAAE;cACR,CAAC,CAAC;cACF,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,OAAO,CAAC;YAC5B,OAAO;cACL,IAAI,CAACH,QAAQ,CAACI,KAAK,CAACX,GAAG,CAACY,GAAG,CAAC;YAC9B;UACF,CAAC;QACH;MACF,CAAC,CAAC;IACJ;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}