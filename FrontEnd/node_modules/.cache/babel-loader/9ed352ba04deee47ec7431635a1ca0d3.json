{"ast":null,"code":"// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\nimport Header from \"@/components/Header\";\nexport default {\n  components: {\n    Header,\n    Aside\n  },\n  data() {\n    const item = {\n      date: '2016-05-02',\n      name: '王小虎',\n      address: '上海市普陀区金沙江路 1518 弄'\n    };\n    return {\n      tableData: Array(10).fill(item),\n      msg: \"hello world\",\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      email: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      form: {}\n    };\n  },\n  created() {\n    //请求分页查询\n    this.query();\n  },\n  methods: {\n    collapse() {\n      this.isCollapse = !this.isCollapse;\n      if (this.isCollapse) {\n        this.sideWidth = 64;\n        this.collapseBtnClass = \"el-icon-s-unfold\";\n        this.logoTextShow = false;\n      } else {\n        this.sideWidth = 200;\n        this.collapseBtnClass = \"el-icon-s-fold\";\n        this.logoTextShow = true;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AAsBA;AACA;AACA;AACA;AAEA;EACAA;IAAAC;IAAAC;EAAA;EACAC;IACA;MACAC;MACAC;MACAC;IACA;IACA;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAV;MACAW;MACAC;MACAC;MACAC;MACAC;IACA;EACA;EACAC;IACA;IACA;EACA;EACAC;IACAC;MACA;MACA;QACA;QACA;QACA;MACA;QACA;QACA;QACA;MACA;IACA;EACA;AACA","names":["components","Header","Aside","data","date","name","address","tableData","msg","collapseBtnClass","isCollapse","sideWidth","logoTextShow","headerBg","pageNum","pageSize","username","email","total","dialogFormVisible","multipleSelection","form","created","methods","collapse"],"sourceRoot":"src/views","sources":["Manage.vue"],"sourcesContent":["<template>\n  <div style=\"height:100%\">\n    <el-container style=\"min-height: 100vh;\">\n      <el-aside :width=\"sideWidth+'px'\" style=\"background-color: rgb(238,241,246); box-shadow: 2px 0 6px rgb(0 21 41 / 35%)\">\n        <Aside :isCollapse=\"isCollapse\" :logoTextShow=\"logoTextShow\"/>\n      </el-aside>\n\n      <el-container>\n        <el-header style=\"border-bottom: 1px solid #ccc;\">\n          <Header :isCollapse=\"isCollapse\" :logoTextShow=\"logoTextShow\"/>\n        </el-header>\n\n        <el-main>\n<!--          表示当前页面子路由会在router-view中显示-->\n          <router-view/>\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\n// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\nimport Header from \"@/components/Header\";\n\nexport default {\n  components: {Header, Aside},\n  data() {\n     const item = {\n            date: '2016-05-02',\n            name: '王小虎',\n            address: '上海市普陀区金沙江路 1518 弄'\n          };\n          return {\n            tableData: Array(10).fill(item),\n            msg:\"hello world\",\n            collapseBtnClass:\"el-icon-s-fold\",\n            isCollapse:false,\n            sideWidth:200,\n            logoTextShow:true,\n            headerBg:\"headerBg\",\n            pageNum:1,\n            pageSize:5,\n            username:\"\",\n            address: \"\",\n            email: \"\",\n            total:0,\n            dialogFormVisible: false,\n            multipleSelection: [],\n            form: {}\n          }\n  },\n  created() {\n    //请求分页查询\n    this.query();\n  },\n  methods:{\n    collapse(){\n      this.isCollapse = !this.isCollapse;\n      if(this.isCollapse){\n        this.sideWidth = 64;\n        this.collapseBtnClass=\"el-icon-s-unfold\"\n        this.logoTextShow = false\n      }else{\n        this.sideWidth = 200;\n        this.collapseBtnClass=\"el-icon-s-fold\"\n        this.logoTextShow = true\n      }\n    },\n  }\n}\n</script>\n<style>\n.headerBg{\n  background: #eee!important;\n}\n.el-menu-vertical-demo:not(.el-menu--collapse){\n  width: 200px;\n  height: 100%;\n}\n.el-menu-vertical-demo{\n  transition: width 1s;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}