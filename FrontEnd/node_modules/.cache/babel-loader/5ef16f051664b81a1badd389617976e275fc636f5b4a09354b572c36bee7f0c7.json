{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"File\",\n  data() {\n    return {\n      tableData: [],\n      name: '',\n      multipleSelection: [],\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      total: 0\n    };\n  },\n  created() {\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/file/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.name\n        }\n      }).then(res => {\n        console.log(res);\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      });\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/file/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        });\n        console.log(ids);\n        this.request.post(\"/file/deleteBatch\", ids).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleFileUploadSuccess(res) {\n      console.log(res);\n      this.query();\n    },\n    downLoad(url) {\n      window.open(url);\n    },\n    handleEnable(row) {\n      this.request.post(\"/file/update\", row).then(res => {\n        if (res.code === '200') {\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          });\n        } else {\n          this.$message.error('操作失败');\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","tableData","multipleSelection","headerBg","pageNum","pageSize","total","created","query","methods","handleSizeChange","val","console","log","handleCurrentChange","request","get","params","then","res","records","reset","handleEdit","row","form","dialogFormVisible","handleDelete","id","$confirm","confirmButtonText","cancelButtonText","type","delete","code","$message","message","error","catch","handleSelectionChange","deleteBatch","length","ids","forEach","item","push","post","handleFileUploadSuccess","downLoad","url","window","open","handleEnable"],"sources":["src/views/File.vue"],"sourcesContent":["<template>\n  <div>\n\n    <div style=\"padding: 10px 0\">\n      <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"name\"></el-input>\n      <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n      <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <div style=\"padding: 10px 0\">\n      <el-upload\n          action=\"http://127.0.0.1:8000/file/upload\" :show-file-list=\"false\" accept=\"xlsx\" :on-success=\"handleFileUploadSuccess\" style=\"display: inline-block\"> <!--上传地址-->\n        <el-button type=\"primary\" class=\"ml-5\">上传<i class=\"el-icon-top\"></i> </el-button>\n      </el-upload>\n      <el-button type=\"danger\" @click=\"deleteBatch\" style=\"display:inline-block; margin-left: 10px;\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n\n    </div>\n    <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n      </el-table-column>\n      <el-table-column prop=\"name\" label=\"文件名称\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"type\" label=\"文件类型\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"size\" label=\"文件大小(kb)\" width=\"200\">\n      </el-table-column>\n      <el-table-column  label=\"下载\" width=\"120\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"primary\" @click=\"downLoad(scope.row.url)\">下载\n            <i class=\"el-icon-download\"></i> </el-button>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"启用\">\n        <template slot-scope=\"scope\">\n          <el-switch\n              v-model=\"scope.row.enable\"\n              active-color=\"#13ce66\"\n              inactive-color=\"#ff4949\"\n              @change=\"handleEnable(scope.row)\"\n          >\n          </el-switch>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div style=\"padding: 10px 0\">\n      <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"pageNum\"\n          :page-sizes=\"[5, 10, 15, 20]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n      </el-pagination>\n    </div>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"File\",\n  data(){\n    return{\n      tableData:[],\n      name:'',\n      multipleSelection: [],\n      headerBg: \"headerBg\",\n      pageNum:1,\n      pageSize:5,\n      total:0\n    }\n  },\n  created() {\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/file/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.name,\n        }\n      }).then(res => {\n        console.log(res)\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      })\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/file/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些文件, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        })\n        console.log(ids);\n        this.request.post(\"/file/deleteBatch\", ids).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleFileUploadSuccess(res) {\n      console.log(res);\n      this.query();\n    },\n    downLoad(url) {\n      window.open(url);\n    },\n    handleEnable(row){\n      this.request.post(\"/file/update\",row).then(res=>{\n        if(res.code==='200'){\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          });\n        }else{\n          this.$message.error('操作失败');\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.headerBg{\n  background: #eee!important;\n}\n</style>"],"mappings":";;;AAkEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAF,IAAA;MACAG,iBAAA;MACAC,QAAA;MACAC,OAAA;MACAC,QAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,KAAA;EACA;EACAC,OAAA;IACAC,iBAAAC,GAAA;MACAC,OAAA,CAAAC,GAAA,OAAAF,GAAA;MACA,KAAAN,QAAA,GAAAM,GAAA;MACA,KAAAP,OAAA;MACA,KAAAI,KAAA;IACA;IACAM,oBAAAH,GAAA;MACAC,OAAA,CAAAC,GAAA,SAAAF,GAAA;MACA,KAAAP,OAAA,GAAAO,GAAA;MACA,KAAAH,KAAA;IACA;IACAA,MAAA;MACA,KAAAO,OAAA,CAAAC,GAAA;QACAC,MAAA;UACAb,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAN,IAAA,OAAAA;QACA;MACA,GAAAmB,IAAA,CAAAC,GAAA;QACAP,OAAA,CAAAC,GAAA,CAAAM,GAAA;QACA,KAAAlB,SAAA,GAAAkB,GAAA,CAAAnB,IAAA,CAAAoB,OAAA;QACA,KAAAd,KAAA,GAAAa,GAAA,CAAAnB,IAAA,CAAAM,KAAA;MACA;IACA;IACAe,MAAA;MACA,KAAAtB,IAAA;MACA,KAAAS,KAAA;IACA;IACAc,WAAAC,GAAA;MACA,KAAAC,IAAA,GAAAD,GAAA;MACA,KAAAE,iBAAA;IACA;IACAC,aAAAC,EAAA;MACA,KAAAC,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAb,IAAA;QACA,KAAAH,OAAA,CAAAiB,MAAA,YAAAL,EAAA,EAAAT,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAc,IAAA;YACA,KAAAC,QAAA;cACAC,OAAA;cACAJ,IAAA;YACA;YACA,KAAAvB,KAAA;UACA;YACA,KAAA0B,QAAA,CAAAE,KAAA;UACA;QACA;MACA,GAAAC,KAAA;QACA,KAAAH,QAAA;UACAH,IAAA;UACAI,OAAA;QACA;MACA;IACA;IACAG,sBAAA3B,GAAA;MACAC,OAAA,CAAAC,GAAA,CAAAF,GAAA;MACA,KAAAT,iBAAA,GAAAS,GAAA;IACA;IACA4B,YAAA;MACA,SAAArC,iBAAA,CAAAsC,MAAA;QACA,KAAAN,QAAA;UACAC,OAAA;UACAJ,IAAA;QACA;QACA;MACA;MACA,KAAAH,QAAA;QACAC,iBAAA;QACAC,gBAAA;QACAC,IAAA;MACA,GAAAb,IAAA;QACA,IAAAuB,GAAA;QACA,KAAAvC,iBAAA,CAAAwC,OAAA,CAAAC,IAAA;UACAF,GAAA,CAAAG,IAAA,CAAAD,IAAA,CAAAhB,EAAA;QACA;QACAf,OAAA,CAAAC,GAAA,CAAA4B,GAAA;QACA,KAAA1B,OAAA,CAAA8B,IAAA,sBAAAJ,GAAA,EAAAvB,IAAA,CAAAC,GAAA;UACA,IAAAA,GAAA,CAAAc,IAAA;YACA,KAAAC,QAAA;cACAC,OAAA;cACAJ,IAAA;YACA;YACA,KAAAvB,KAAA;UACA;YACA,KAAA0B,QAAA,CAAAE,KAAA;UACA;QACA;MACA,GAAAC,KAAA;QACA,KAAAH,QAAA;UACAH,IAAA;UACAI,OA