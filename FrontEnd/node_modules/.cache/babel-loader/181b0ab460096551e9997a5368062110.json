{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"role\",\n  data() {\n    return {\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      name: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      menuDialogVis: false,\n      multipleSelection: [],\n      tableData: [],\n      form: {}\n    };\n  },\n  created() {\n    //分页查询\n    this.query();\n  },\n  methods: {\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize = val;\n      this.pageNum = 1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum = val;\n      this.query();\n    },\n    query() {\n      this.request.get(\"/role/page?\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.name\n        }\n      }).then(res => {\n        console.log(res);\n        this.tableData = res.data.records;\n        this.total = res.data.total;\n      });\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleAdd() {\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save() {\n      this.dialogFormVisible = false;\n      this.request.post(\"/role\", this.form).then(res => {\n        if (res.code === '200') {\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        } else {\n          this.$message.error('保存失败');\n        }\n      });\n    },\n    handleEdit(row) {\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id) {\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/role/\" + id).then(res => {\n          if (res.code === '200') {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val) {\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        });\n        console.log(ids);\n        this.request.post(\"/role/deleteBatch\", ids).then(res => {\n          if (res.data) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    exp() {\n      this.$confirm('此操作将导出用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        window.open(\"http://localhost:8090/role/export\");\n        this.$message({\n          message: '导出成功',\n          type: 'success'\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消导出'\n        });\n      });\n    },\n    handleExcelImportSuccess() {\n      this.$message({\n        message: '导入成功',\n        type: 'success'\n      });\n      this.query();\n    },\n    selectMenu(roleId) {\n      this.menuDialogVis = true;\n    },\n    handleCheckChange(data, checked, indeterminate) {\n      console.log(data, checked, indeterminate);\n    }\n  }\n};","map":{"version":3,"mappings":";AAmFA;EACAA;EACAC;IACA;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAR;MACAS;MACAC;MACAC;MACAC;MACAC;MACAC;IACA;EACA;EACAC;IACA;IACA;EACA;EACAC;IACAC;MACAC;MACA;MACA;MACA;IACA;IACAC;MACAD;MACA;MACA;IACA;IACAE;MACA;QACAC;UACAd;UACAC;UACAR;QACA;MAAA;QACAkB;QACA;QACA;MACA;IACA;IACAI;MACA;MACA;IACA;IACAC;MACA;MACA;IACA;IACAC;MACA;MACA;QACA;UACA;YACAC;YACAC;UACA;UACA;QACA;UACA;QACA;MACA;IACA;IACAC;MACA;MACA;IACA;IACAC;MACA;QACAC;QACAC;QACAJ;MACA;QACA;UACA;YACA;cACAD;cACAC;YACA;YACA;UACA;YACA;UACA;QACA;MACA;QACA;UACAA;UACAD;QACA;MACA;IACA;IACAM;MACAb;MACA;IACA;IACAc;MACA;QACA;UACAP;UACAC;QACA;QACA;MACA;MACA;QACAG;QACAC;QACAJ;MACA;QACA;QACA;UACAO;QACA;QACAf;QACA;UACA;YACA;cACAO;cACAC;YACA;YACA;UACA;YACA;UACA;QACA;MACA;QACA;UACAA;UACAD;QACA;MACA;IACA;IACAS;MACA;QACAL;QACAC;QACAJ;MACA;QAEAS;QACA;UACAV;UACAC;QACA;MACA;QACA;UACAA;UACAD;QACA;MACA;IACA;IACAW;MACA;QACAX;QACAC;MACA;MACA;IACA;IACAW;MACA;IACA;IACAC;MACApB;IACA;EAEA;AACA","names":["name","data","collapseBtnClass","isCollapse","sideWidth","logoTextShow","headerBg","pageNum","pageSize","total","dialogFormVisible","menuDialogVis","multipleSelection","tableData","form","created","methods","handleSizeChange","console","handleCurrentChange","query","params","reset","handleAdd","save","message","type","handleEdit","handleDelete","confirmButtonText","cancelButtonText","handleSelectionChange","deleteBatch","ids","exp","window","handleExcelImportSuccess","selectMenu","handleCheckChange"],"sourceRoot":"src/views","sources":["Role.vue"],"sourcesContent":["<template>\n  <div>\n\n    <div style=\"padding: 10px 0\">\n      <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"name\"></el-input>\n<!--      <el-input style=\"width: 200px\" placeholder=\"请输入邮箱\" suffix-icon=\"el-icon-message\" v-model=\"email\" class=\"ml-5\"></el-input>\n      <el-input style=\"width: 200px\" placeholder=\"请输入地址\" suffix-icon=\"el-icon-position\" v-model=\"address\" class=\"ml-5\"></el-input>-->\n      <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n      <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <div style=\"padding: 10px 0\">\n      <el-button type=\"primary\" @click=\"handleAdd\">新增<i class=\"el-icon-circle-plus-outline\"></i> </el-button>\n      <el-button type=\"danger\" @click=\"deleteBatch\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n<!--      <el-upload\n          action=\"http://localhost:8090/user/import\" :show-file-list=\"false\" accept=\"xlsx\" :on-success=\"handleExcelImportSuccess\" style=\"display: inline-block\"> &lt;!&ndash;上传地址&ndash;&gt;\n      <el-button type=\"primary\" class=\"ml-5\">导入<i class=\"el-icon-bottom\"></i> </el-button>\n      </el-upload>\n      <el-button type=\"primary\" @click=\"exp\" class=\"ml-5\">导出<i class=\"el-icon-top\"></i> </el-button>-->\n    </div>\n\n    <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n      </el-table-column>\n      <el-table-column prop=\"name\" label=\"名称\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"description\" label=\"描述\">\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"text\" size=\"small\" @click=\"selectMenu(scope.row.id)\">分配菜单<i class=\"el-icon-menu\"></i></el-button>\n          <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row.id)\">编辑<i class=\"el-icon-edit\"></i> </el-button>\n          <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div style=\"padding: 10px 0\">\n      <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"pageNum\"\n          :page-sizes=\"[5, 10, 15, 20]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n      </el-pagination>\n    </div>\n\n    <el-dialog title=\"角色信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\n      <el-form label-width=\"80px\">\n        <el-form-item label=\"\" style=\"display: none\">\n          <el-input v-model=\"form.id\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"名称\">\n          <el-input v-model=\"form.name\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"描述\">\n          <el-input v-model=\"form.description\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save()\">确 定</el-button>\n      </div>\n    </el-dialog>\n\n    <el-dialog title=\"菜单分配\" :visible.sync=\"menuDialogVis\" width=\"30%\">\n      <el-tree\n        :data=\"memuData\"\n        show-checkbox\n        @check-change=\"handleCheckChange\">\n      </el-tree>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"menuDialogVis = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save()\">确 定</el-button>\n      </div>\n    </el-dialog>\n\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"role\",\n  data() {\n    return {\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      name: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      menuDialogVis: false,\n      multipleSelection: [],\n      tableData: [],\n      form:{},\n    }\n  },\n  created() {\n    //分页查询\n    this.query();\n  },\n  methods:{\n    handleSizeChange(val) {\n      console.log(`每页 ${val} 条`);\n      this.pageSize=val;\n      this.pageNum=1;\n      this.query();\n    },\n    handleCurrentChange(val) {\n      console.log(`当前页: ${val}`);\n      this.pageNum=val;\n      this.query();\n    },\n    query(){\n      this.request.get(\"/role/page?\",{\n        params:{\n          pageNum:this.pageNum,\n          pageSize:this.pageSize,\n          name:this.name,\n        }}).then(res=>{\n        console.log(res)\n        this.tableData = res.data.records;\n        this.total=res.data.total;\n      })\n    },\n    reset() {\n      this.name = \"\";\n      this.query();\n    },\n    handleAdd(){\n      this.dialogFormVisible = true;\n      this.form = {};\n    },\n    save(){\n      this.dialogFormVisible = false;\n      this.request.post(\"/role\",this.form).then(res=>{\n        if(res.code==='200'){\n          this.$message({\n            message: '保存成功',\n            type: 'success'\n          });\n          this.query();\n        }else {\n          this.$message.error('保存失败');\n        }\n      })\n    },\n    handleEdit(row){\n      this.form = row;\n      this.dialogFormVisible = true;\n    },\n    handleDelete(id){\n      this.$confirm('此操作将永久删除该用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.request.delete(\"/role/\"+id).then(res=>{\n          if(res.code==='200'){\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          }else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelectionChange(val){\n      console.log(val);\n      this.multipleSelection = val;\n    },\n    deleteBatch() {\n      if (this.multipleSelection.length == 0) {\n        this.$message({\n          message: '请至少选择一条数据',\n          type: 'warning'\n        });\n        return;\n      }\n      this.$confirm('此操作将永久删除这些用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        let ids = [];\n        this.multipleSelection.forEach(item => {\n          ids.push(item.id);\n        })\n        console.log(ids);\n        this.request.post(\"/role/deleteBatch\", ids).then(res => {\n          if (res.data) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            });\n            this.query();\n          } else {\n            this.$message.error('删除失败');\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    exp(){\n      this.$confirm('此操作将导出用户, 是否继续?', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n\n        window.open(\"http://localhost:8090/role/export\");\n        this.$message({\n          message: '导出成功',\n          type: 'success'\n        });\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消导出'\n        });\n      });\n    },\n    handleExcelImportSuccess(){\n      this.$message({\n        message: '导入成功',\n        type: 'success'\n      });\n      this.query();\n    },\n    selectMenu(roleId){\n      this.menuDialogVis = true;\n    },\n    handleCheckChange(data, checked, indeterminate) {\n      console.log(data, checked, indeterminate);\n    },\n\n  }\n}\n</script>\n\n<style>\n.headerBg{\n  background: #eee!important;\n}\n.el-menu-vertical-demo:not(.el-menu--collapse){\n  width: 200px;\n  height: 100%;\n}\n.el-menu-vertical-demo{\n  transition: width 1s;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}