{"ast":null,"code":"export default {\n  name: \"User\",\n  data() {\n    return {\n      tableData: Array(10).fill(item),\n      msg: \"hello world\",\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      headerBg: \"headerBg\",\n      pageNum: 1,\n      pageSize: 5,\n      username: \"\",\n      address: \"\",\n      email: \"\",\n      total: 0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      form: {}\n    };\n  }\n};","map":{"version":3,"mappings":"AAyFA;EACAA;EACAC;IACA;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;IACA;EACA;AACA","names":["name","data","tableData","msg","collapseBtnClass","isCollapse","sideWidth","logoTextShow","headerBg","pageNum","pageSize","username","address","email","total","dialogFormVisible","multipleSelection","form"],"sourceRoot":"src/views","sources":["User.vue"],"sourcesContent":["<template>\n  <div>\n\n    <div style=\"margin-bottom: 30px\">\n      <el-breadcrumb separator=\"/\">\n        <el-breadcrumb-item :to=\"{ path: '/' }\">首页</el-breadcrumb-item>\n        <el-breadcrumb-item><a href=\"/\">用户管理</a></el-breadcrumb-item>\n      </el-breadcrumb>\n    </div>\n\n\n    <div style=\"padding: 10px 0\">\n      <el-input style=\"width: 200px\" placeholder=\"请输入名称\" suffix-icon=\"el-icon-search\" v-model=\"username\"></el-input>\n      <el-input style=\"width: 200px\" placeholder=\"请输入邮箱\" suffix-icon=\"el-icon-message\" v-model=\"email\" class=\"ml-5\"></el-input>\n      <el-input style=\"width: 200px\" placeholder=\"请输入地址\" suffix-icon=\"el-icon-position\" v-model=\"address\" class=\"ml-5\"></el-input>\n      <el-button class=\"ml-5\" type=\"primary\" @click=\"query\">搜索</el-button>\n      <el-button class=\"ml-5\" type=\"warning\" @click=\"reset\" >重置</el-button>\n    </div>\n\n    <div style=\"padding: 10px 0\">\n      <el-button type=\"primary\" @click=\"handleAdd\">新增<i class=\"el-icon-circle-plus-outline\"></i> </el-button>\n      <el-button type=\"danger\" @click=\"deleteBatch\">批量删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n      <el-button type=\"primary\">导入<i class=\"el-icon-bottom\"></i> </el-button>\n      <el-button type=\"primary\">导出<i class=\"el-icon-top\"></i> </el-button>\n    </div>\n\n    <el-table :data=\"tableData\" border stripe :header-cell-class-name=\"headerBg\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\"  width=\"55\"></el-table-column>\n      <el-table-column prop=\"id\" label=\"ID\" width=\"80\">\n      </el-table-column>\n      <el-table-column prop=\"username\" label=\"姓名\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"nickname\" label=\"昵称\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"email\" label=\"邮箱\" width=\"200\">\n      </el-table-column>\n      <el-table-column prop=\"phone\" label=\"电话\" width=\"120\">\n      </el-table-column>\n      <el-table-column prop=\"address\" label=\"地址\">\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"text\" size=\"small\" @click=\"handleEdit(scope.row)\">编辑<i class=\"el-icon-edit\"></i> </el-button>\n          <el-button type=\"text\" size=\"small\" @click=\"handleDelete(scope.row.id)\">删除<i class=\"el-icon-remove-outline\"></i> </el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div style=\"padding: 10px 0\">\n      <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"pageNum\"\n          :page-sizes=\"[5, 10, 15, 20]\"\n          :page-size=\"pageSize\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          :total=\"total\">\n      </el-pagination>\n    </div>\n\n    <el-dialog title=\"用户信息\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\n      <el-form label-width=\"80px\">\n        <el-form-item label=\"\" style=\"display: none\">\n          <el-input v-model=\"form.id\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"用户名\">\n          <el-input v-model=\"form.username\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"昵称\">\n          <el-input v-model=\"form.nickname\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"电话\">\n          <el-input v-model=\"form.phone\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"邮箱\">\n          <el-input v-model=\"form.email\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"地址\">\n          <el-input v-model=\"form.address\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save()\">确 定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"User\",\n  data(){\n    return {\n      tableData: Array(10).fill(item),\n      msg:\"hello world\",\n      collapseBtnClass:\"el-icon-s-fold\",\n      isCollapse:false,\n      sideWidth:200,\n      logoTextShow:true,\n      headerBg:\"headerBg\",\n      pageNum:1,\n      pageSize:5,\n      username:\"\",\n      address: \"\",\n      email: \"\",\n      total:0,\n      dialogFormVisible: false,\n      multipleSelection: [],\n      form: {}\n    }\n  }\n}\n</script>\n\n<style scoped>\n\n</style>"]},"metadata":{},"sourceType":"module"}