{"ast":null,"code":"// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\nimport Header from \"@/components/Header\";\nexport default {\n  components: {\n    Header,\n    Aside\n  },\n  data() {\n    return {\n      collapseBtnClass: \"el-icon-s-fold\",\n      isCollapse: false,\n      sideWidth: 200,\n      logoTextShow: true,\n      pathName: \"\",\n      user: localStorage.getItem(\"user\") ? JSON.parse(localStorage.getItem(\"user\")) : {}\n    };\n  },\n  created() {},\n  methods: {\n    collapse() {\n      this.isCollapse = !this.isCollapse;\n      if (this.isCollapse) {\n        this.sideWidth = 64;\n        this.collapseBtnClass = \"el-icon-s-unfold\";\n        this.logoTextShow = false;\n      } else {\n        this.sideWidth = 200;\n        this.collapseBtnClass = \"el-icon-s-fold\";\n        this.logoTextShow = true;\n      }\n    },\n    getUser() {\n      this.request.get(\"/user/username/\" + this.user.username).then(res => {\n        //重新赋值后台的最新User信息\n        this.user = res.data;\n      });\n    }\n  }\n};","map":{"version":3,"mappings":"AAuBA;AACA;AACA;AACA;AAEA;EACAA;IAAAC;IAAAC;EAAA;EACAC;IACA;MACAC;MACAC;MACAC;MACAC;MACAC;MACAC;IACA;EACA;EACAC,WAEA;EACAC;IACAC;MACA;MACA;QACA;QACA;QACA;MACA;QACA;QACA;QACA;MACA;IACA;IACAC;MACA;QACA;QACA;MACA;IACA;EACA;AACA","names":["components","Header","Aside","data","collapseBtnClass","isCollapse","sideWidth","logoTextShow","pathName","user","created","methods","collapse","getUser"],"sourceRoot":"src/views","sources":["Manage.vue"],"sourcesContent":["<template>\n  <div style=\"height:100%\">\n    <el-container style=\"min-height: 100vh;\">\n\n      <el-aside :width=\"sideWidth+'px'\" style=\"background-color: rgb(238,241,246); box-shadow: 2px 0 6px rgb(0 21 41 / 35%)\">\n        <Aside :isCollapse=\"isCollapse\" :logoTextShow=\"logoTextShow\"/>\n      </el-aside>\n\n      <el-container>\n        <el-header style=\"border-bottom: 1px solid #ccc;\">\n          <Header :collapseBtnClass=\"collapseBtnClass\" :collapse=\"isCollapse\" :user=\"user\" />\n        </el-header>\n\n        <el-main>\n<!--          表示当前页面子路由会在router-view中显示-->\n          <router-view @refreshUser=\"getUser\"/>\n        </el-main>\n      </el-container>\n    </el-container>\n  </div>\n</template>\n\n<script>\n// @ is an alias to /src\nimport HelloWorld from '@/components/HelloWorld.vue';\nimport Aside from '@/components/Aside';\nimport Header from \"@/components/Header\";\n\nexport default {\n  components: {Header, Aside},\n  data() {\n          return {\n            collapseBtnClass:\"el-icon-s-fold\",\n            isCollapse:false,\n            sideWidth:200,\n            logoTextShow:true,\n            pathName:\"\",\n            user:localStorage.getItem(\"user\")?JSON.parse(localStorage.getItem(\"user\")):{}\n          }\n  },\n  created() {\n\n  },\n  methods:{\n    collapse(){\n      this.isCollapse = !this.isCollapse;\n      if(this.isCollapse){\n        this.sideWidth = 64;\n        this.collapseBtnClass=\"el-icon-s-unfold\"\n        this.logoTextShow = false\n      }else{\n        this.sideWidth = 200;\n        this.collapseBtnClass=\"el-icon-s-fold\"\n        this.logoTextShow = true\n      }\n    },\n    getUser(){\n      this.request.get(\"/user/username/\"+this.user.username).then(res=>{\n        //重新赋值后台的最新User信息\n        this.user=res.data;\n      })\n    }\n  }\n}\n</script>\n<style>\n.headerBg{\n  background: #eee!important;\n}\n.el-menu-vertical-demo:not(.el-menu--collapse){\n  width: 200px;\n  height: 100%;\n}\n.el-menu-vertical-demo{\n  transition: width 1s;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}