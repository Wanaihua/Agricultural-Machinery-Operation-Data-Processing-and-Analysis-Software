{"ast":null,"code":"export default {\n  name: \"404\"\n};","map":{"version":3,"mappings":"AA4CA;EACAA;AACA","names":["name"],"sourceRoot":"src/views","sources":["404.vue"],"sourcesContent":["<template>\n  <div>\n    <el-dialog title=\"添加菜单\" :visible.sync=\"dialogFormVisible\" width=\"30%\">\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"80px\">\n        <el-form-item label=\"菜单名称\" prop=\"name\">\n          <el-input v-model=\"form.name\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"菜单路径\" prop=\"path\">\n          <el-input v-model=\"form.path\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"菜单图标\" prop=\"icon\">\n          <el-input v-model=\"form.icon\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"菜单排序\" prop=\"sort\">\n          <el-input v-model=\"form.sort\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"菜单类型\" prop=\"type\">\n          <el-select v-model=\"form.type\" placeholder=\"请选择\">\n            <el-option label=\"菜单\" value=\"0\"></el-option>\n            <el-option label=\"按钮\" value=\"1\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"菜单状态\" prop=\"status\">\n          <el-select v-model=\"form.status\" placeholder=\"请选择\">\n            <el-option label=\"显示\" value=\"0\"></el-option>\n            <el-option label=\"隐藏\" value=\"1\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"菜单权限\" prop=\"permission\">\n          <el-input v-model=\"form.permission\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"菜单备注\" prop=\"remark\">\n          <el-input v-model=\"form.remark\"></el-input>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"save\">确 定</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"404\"\n}\n</script>\n\n<style scoped>\n\n</style>"]},"metadata":{},"sourceType":"module"}