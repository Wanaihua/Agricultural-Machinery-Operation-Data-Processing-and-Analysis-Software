","color"],"sources":["src/views/Home.vue"],"sourcesContent":["<template>\n  <div>\n    <el-row :gutter=\"10\" style=\"margin-buttom:40px\">\n      <el-col :span=\"6\">\n        <el-card  style=\"color: #409EFF\">\n          <div><i class=\"el-icon-user-solid\"></i>用户总数</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            100\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #F56C6C\">\n          <div><i class=\"el-icon-money\"></i>销售总量</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            ￥ 1000000\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #67C23A\">\n          <div><i class=\"el-icon-bank-card\"></i>收益总额</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            ￥ 3000000\n          </div>\n        </el-card>\n      </el-col>\n      <el-col :span=\"6\">\n        <el-card style=\"color: #E6A23C\">\n          <div><i class=\"el-icon-s-shop\"></i>门店总数</div>\n          <div style=\"padding: 10px 0;text-align: center;font-weight: bold\">\n            300\n          </div>\n        </el-card>\n      </el-col>\n    </el-row>\n    <el-row style=\"margin-top: 50px;\">\n      <el-col :span=\"12\">\n        <div id=\"main\" style=\"width: 500px;height: 450px;\"></div>\n      </el-col>\n\n      <el-col :span=\"12\">\n        <div id=\"pie\" style=\"width: 1000px;height: 400px;\"></div>\n      </el-col>\n    </el-row>\n\n\n\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: \"Home\",\n  data(){\n    return{\n\n    }\n  },\n  mounted() {  //页面元素加载完成后执行\n\n    var option,pie;\n\n    option = {\n      title: {\n        text: '各季度会员数量统计',\n        subtext: '趋势图',\n        left: 'center'\n      },\n      tooltip: {\n        trigger: 'item'\n      },\n      legend: {\