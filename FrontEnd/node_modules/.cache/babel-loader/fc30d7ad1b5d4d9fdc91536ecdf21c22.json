{"ast":null,"code":"export default {\n  name: \"Aside\",\n  props: {\n    isCollapse: Boolean,\n    logoTextShow: Boolean\n  },\n  data() {\n    return {\n      menus: localStorage.getItem(\"menus\") ? JSON.parse(localStorage.getItem(\"menus\")) : []\n    };\n  },\n  methods: {\n    handleSelect() {\n      this.$route.fullPath.split(\"/\");\n    }\n  }\n};","map":{"version":3,"mappings":"AA6CA;EACAA;EACAC;IACAC;IACAC;EACA;EACAC;IACA;MACAC;IACA;EACA;EACAC;IACAC;MACA;IACA;EACA;AACA","names":["name","props","isCollapse","logoTextShow","data","menus","methods","handleSelect"],"sourceRoot":"src/components","sources":["Aside.vue"],"sourcesContent":["<template>\n  <el-menu :default-openeds=\"['1', '3']\" style=\"min-height: 100%;overflow-x: hidden;\"\n           background-color=\"rgb(48,65,86)\"\n           text-color=\"#fff\"\n           active-text-color=\"#ffd04b\"\n           :collapse-transition=\"false\"\n           :collapse=\"isCollapse\"\n           router\n           @select=\"handleSelect\"\n           class=\"el-menu-vertical-demo\">\n    <div style=\"height: 60px;line-height: 60px;text-align: center\">\n      <img src=\"../assets/logo.png\" alt=\"\" style=\"width:20px;position: relative;top: 3px;margin-right: 5px\">\n      <span style=\"color: white\" v-show=\"logoTextShow\">后台管理系统</span>\n    </div>\n\n    <div v-for=\"item in menus\" :key=\"item.id\">\n      <div v-if=\"item.children\">\n        <el-menu-item :index=\"item.path\">\n          <template slot=\"title\">\n            <i :class=\"item.icon\"></i>\n            <span slot=\"title\">{{item.name}}</span>\n          </template>\n        </el-menu-item>\n      </div>\n      <div v-else>\n        <el-submenu :index=\"item.id\">\n          <template slot=\"title\">\n            <i :class=\"item.icon\"></i>\n            <span slot=\"title\">{{item.name}}</span>\n          </template>\n          <div v-for=\"subItem in item.children\" :key=\"subItem.id\">\n            <el-menu-item :index=\"subItem.path\">\n              <template slot=\"title\">\n                <i :class=\"subItem.icon\"></i>\n                <span slot=\"title\">{{subItem.name}}</span>\n              </template>\n            </el-menu-item>\n          </div>\n        </el-submenu>\n      </div>\n    </div>\n  </el-menu>\n</template>\n\n<script>\nexport default {\n  name: \"Aside\",\n  props:{\n    isCollapse:Boolean,\n    logoTextShow:Boolean,\n  },\n  data(){\n    return{\n      menus:localStorage.getItem(\"menus\")?JSON.parse(localStorage.getItem(\"menus\")):[]\n    }\n  },\n  methods:{\n    handleSelect() {\n      this.$route.fullPath.split(\"/\")\n    }\n  }\n}\n</script>\n\n<style scoped>\n\n</style>"]},"metadata":{},"sourceType":"module"}